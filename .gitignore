# ─── TeamSoft FF Studio - GitIgnore ───

# Dependências (Nunca subir)
node_modules/
backend/node_modules/
frontend_flutter/node_modules/
.pub-cache/
.dart_tool/

# Builds e Binários
build/
frontend_flutter/build/
*.exe
*.dll
*.so
*.ipa
*.apk

# Arquivos de Projeto Exportados (Ocupam muito espaço)
# Se você quiser salvar o código exportado no Git, comente a linha abaixo
projects/

# Logs e Arquivos Temporários (Lixo de execução)
*.log
*.txt
*.bak
logs/
temp/
backend/debug_attach.txt
backend/error.txt
backend/out.txt
*.json_dump

# Configurações Pessoais e Chaves de API
# Importante: Não subir sua chave do Gemini ou OpenAI
config.json
.env
backend/config.json

# IDEs e Editores
.idea/
.vscode/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Pastas da Arquitetura Antiga (Caso você ainda não tenha deletado)
electron/
frontend/
backups/
scripts/
backend/debug_panel_devtool/
backend/debug_panel_proto/
backend/ff_studio/
backend/test/

# Mac OS lixo
.DS_Store